{
  "name": "glossarist",
  "version": "0.1.0",
  "description": "JavaScript library for reading Glossarist GCR packages and v2 concept data",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./gcr": "./src/gcr-reader.js",
    "./concept": "./src/concept-reader.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:verbose": "node --test --test-reporter spec test/*.test.js"
  },
  "keywords": [
    "glossarist",
    "gcr",
    "terminology",
    "glossary",
    "iso",
    "geolexica"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glossarist/glossarist-js"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1"
  }
}
