{
  "name": "glossarist",
  "version": "0.1.5",
  "description": "JavaScript SDK for Glossarist GCR packages — read, write, validate, and manage terminology concepts",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "sideEffects": false,
  "files": [
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./gcr": {
      "types": "./src/gcr-reader.d.ts",
      "import": "./src/gcr-reader.js",
      "default": "./src/gcr-reader.js"
    },
    "./concept": {
      "types": "./src/concept-reader.d.ts",
      "import": "./src/concept-reader.js",
      "default": "./src/concept-reader.js"
    },
    "./models": {
      "types": "./src/models/index.d.ts",
      "import": "./src/models/index.js",
      "default": "./src/models/index.js"
    },
    "./validators": {
      "types": "./src/validators/index.d.ts",
      "import": "./src/validators/index.js",
      "default": "./src/validators/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src/ test/",
    "pretest": "node test/fixtures/build-fixtures.js",
    "test": "find test -name '*.test.js' | sort | xargs node --test",
    "test:verbose": "find test -name '*.test.js' | sort | xargs node --test --test-reporter spec",
    "test:coverage": "find test -name '*.test.js' | sort | xargs node --test --experimental-test-coverage",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "glossarist",
    "gcr",
    "terminology",
    "glossary",
    "iso",
    "geolexica"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glossarist/glossarist-js.git"
  },
  "homepage": "https://github.com/glossarist/glossarist-js#readme",
  "bugs": {
    "url": "https://github.com/glossarist/glossarist-js/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0"
  }
}
